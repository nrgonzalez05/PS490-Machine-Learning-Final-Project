	month = may,
	year = {2018},
	pages = {204--214},
	file = {SAGE PDF Full Text:/Users/nicholasrgonzalez/Zotero/storage/HGPI898P/Craig et al. - 2018 - Racial and Political Dynamics of an Approaching “Majority-Minority” United States.pdf:application/pdf},
}

